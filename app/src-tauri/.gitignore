# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Staged by build\Build-HD365App.ps1: a copy of the repo's PowerShell engine (HD365.psd1/psm1,
# Bridge-HD365.ps1, Private/, Public/, Config/) bundled into the installer as a resource dir.
# Never hand-edit; regenerated on every desktop build.
#
# NOTE: tauri-build validates that every `bundle.resources` source path exists at *compile*
# time - for `cargo check`/`npm run tauri dev` too, not just `tauri build` - so this directory
# must never be fully absent from a fresh checkout, or every build (dev included) fails with
# "resource path `engine` doesn't exist". Ignore everything under it EXCEPT a committed
# `.gitkeep` placeholder that keeps the directory present; Build-HD365App.ps1 restores it after
# wiping/restaging real content.
/engine/*
!/engine/.gitkeep
